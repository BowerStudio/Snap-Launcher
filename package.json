{
	"name": "snap-launcher",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Stream Deck plugin: launch apps and snap their windows to saved positions across monitors.",
	"scripts": {
		"test": "node --test tests/**/*.test.ts",
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.myorg.snap-launcher\""
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^28.0.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.1.0",
		"@types/node": "^24.0.0",
		"rollup": "^4.28.0",
		"tslib": "^2.8.0",
		"typescript": "^5.7.0"
	}
}
